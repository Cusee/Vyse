# vyse-gateway — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
#
# All variables are prefixed VYSE_. They override the corresponding value
# in config.toml. The mapping rule: replace . with _ and prepend VYSE_.
# Example: server.public_port → VYSE_SERVER_PUBLIC_PORT
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED SECRETS ──────────────────────────────────────────────────────────
# These must be set. The gateway will refuse to start without them.

# HMAC-SHA256 signing key for admin JWTs.
# Generate with: openssl rand -hex 32
VYSE_AUTH_JWT_SECRET=

# Password for the admin account at POST /admin/auth/token.
# For production, use a bcrypt hash. For local dev, a plain string is accepted.
# Generate bcrypt: htpasswd -bnBC 12 "" "yourpassword" | tr -d ':\n'
VYSE_AUTH_ADMIN_PASSWORD=

# Shared API key that inference clients must include in X-Vyse-Key.
# Generate with: openssl rand -hex 32
VYSE_AUTH_API_KEY=

# ── ENGINE ────────────────────────────────────────────────────────────────────

# gRPC address of the Rust defence engine.
# Format: host:port
# Default: localhost:50051 (set in config.toml)
VYSE_ENGINE_ADDRESS=localhost:50051

# ── SERVER ────────────────────────────────────────────────────────────────────

# Uncomment to override ports from config.toml.
# VYSE_SERVER_PUBLIC_PORT=8080
# VYSE_SERVER_ADMIN_PORT=8081

# ── LOGGING ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
# Default: info
# VYSE_LOGGING_LEVEL=info

# Log format: json | text
# Use "text" for local development, "json" for production.
# Default: json
# VYSE_LOGGING_FORMAT=json

# ── LIMITS ────────────────────────────────────────────────────────────────────

# Requests per second per IP (default: 10.0)
# VYSE_LIMITS_REQUESTS_PER_SECOND=10.0

# Burst size (default: 20)
# VYSE_LIMITS_BURST=20

# Maximum prompt size in bytes (default: 16384)
# VYSE_LIMITS_MAX_PROMPT_BYTES=16384
